# Look server configuration. Copy to .env for local development.
#
# Look is intended to run on a private Tailscale network. HOST=0.0.0.0 lets
# Tailnet devices reach the server, but you should not publish port 5678 to the
# public internet.

PHOTO_DIR=/path/to/photos
HOST=0.0.0.0
PORT=5678
DB_PATH=~/.local/local-photos/library.db

# Optional. Leave blank for a single-user private Tailnet; set for shared
# Tailnets so write actions require X-API-Key.
API_KEY=

THUMBNAIL_QUALITY=85
MAX_THUMBNAIL_WIDTH=1024
GRID_THUMBNAIL_WIDTH=512
PREVIEW_WORKERS=4
RAW_PREVIEW_HALF_SIZE=true

SMART_ALBUMS_ENABLED=false
DEDUP_ENABLED=false
DEDUP_TOLERANCE=20
TAG_HISTORY_ENABLED=true
AUTO_TAG_GPS=false
AUTO_TAG_CAMERA=false
FILEWATCHER_COOLDOWN=3
